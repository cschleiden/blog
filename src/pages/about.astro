---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About — Christopher Schleiden" description="Staff Software Engineer at GitHub. Building developer tools and infrastructure.">
  <section class="section" style="padding-top: 76px;">
    <div class="container">
      <div class="section-header fade-up">
        <span class="section-title">About</span>
      </div>
      <div class="about-content">
        <p class="about-intro fade-up">
          I'm a <span class="highlight">Staff Software Engineer</span> at GitHub,
          where I'm building AI developer tools. I care deeply about
          developer experience and building tools that get out of your way.
          Originally from <span class="highlight">Cologne</span>, now somewhere
          in the PNW chasing summit views.
        </p>

        <div class="journey stagger">
          <div class="journey-item current fade-up">
            <div class="journey-dot"></div>
            <div class="journey-period">2019 → now</div>
            <div class="journey-role">Staff Software Engineer</div>
            <div class="journey-place">GitHub · AI Developer Tools</div>
            <div class="journey-note">Currently building AI developer tools. Helped launch and scale GitHub Actions, worked on GitHub Models, and contributed to Copilot.</div>
          </div>
          <div class="journey-item fade-up">
            <div class="journey-dot"></div>
            <div class="journey-period">2014 → 2019</div>
            <div class="journey-role">Software Engineer → Principal Engineering Manager</div>
            <div class="journey-place">Microsoft · Redmond, WA</div>
            <div class="journey-note">Moved to Redmond to work on Azure DevOps (formerly Team Foundation Server / Visual Studio Team Services).</div>
            <div class="journey-subs">
              <div class="journey-sub">
                <span class="journey-sub-period">2018 → 2019</span>
                <span class="journey-sub-text">Principal Engineering Manager · Azure Boards</span>
              </div>
              <div class="journey-sub">
                <span class="journey-sub-period">2014 → 2018</span>
                <span class="journey-sub-text">Senior Software Engineer · Team Services</span>
              </div>
            </div>
          </div>
          <div class="journey-item fade-up">
            <div class="journey-dot"></div>
            <div class="journey-period">2011 → 2014</div>
            <div class="journey-role">Consultant</div>
            <div class="journey-place">Microsoft · Germany</div>
            <div class="journey-note">Application development consulting — web and modern client development for enterprise customers.</div>
          </div>
          <div class="journey-item fade-up">
            <div class="journey-dot"></div>
            <div class="journey-period">2007 → 2011</div>
            <div class="journey-role">B.Sc. & M.Sc. Computer Science</div>
            <div class="journey-place"><a href="https://www.rwth-aachen.de">RWTH Aachen University</a> · Germany</div>
            <div class="journey-subs">
              <div class="journey-sub">
                <span class="journey-sub-period">2009 → 2011</span>
                <span class="journey-sub-text">M.Sc. Computer Science</span>
              </div>
              <div class="journey-sub">
                <span class="journey-sub-period">2007 → 2009</span>
                <span class="journey-sub-text">B.Sc. Computer Science</span>
              </div>
            </div>
          </div>
          <div class="journey-item fade-up">
            <div class="journey-dot"></div>
            <div class="journey-role">Grew up in Cologne, Germany</div>
            <div class="journey-place">Köln 🇩🇪</div>
          </div>
        </div>

        <div class="fade-up" style="margin-top: 16px; padding: 24px; border-radius: var(--radius); border: 1px solid var(--border); background: var(--bg-raised);">
          <p style="font-size: 0.85rem; color: var(--text-muted); line-height: 1.7;">
            Disclaimer: The opinions expressed herein are my own and do not represent my employer's views in any way.
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
