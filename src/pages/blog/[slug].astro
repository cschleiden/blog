---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.id.replace(/\.mdx?$/, '') },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<BaseLayout title={`${post.data.title} — Christopher Schleiden`} description={post.data.summary || ''}>
  <article style="padding-top: 140px; padding-bottom: 80px;">
    <div class="container">
      <header class="fade-up" style="margin-bottom: 48px;">
        <div style="display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 16px;">
          {post.data.tags.map((tag: string) => (
            <a href={`/tags/${tag.toLowerCase()}`} class="post-tag">{tag}</a>
          ))}
        </div>
        <h1 style="font-size: clamp(2rem, 5vw, 2.75rem); font-weight: 800; letter-spacing: -0.03em; line-height: 1.15; margin-bottom: 16px;">
          {post.data.title}
        </h1>
        <time class="post-date" datetime={post.data.date.toISOString()}>
          {formatDate(post.data.date)}
        </time>
      </header>
      <div class="prose-blog fade-up">
        <Content />
      </div>
      <div style="margin-top: 64px; padding-top: 32px; border-top: 1px solid var(--border);">
        <a href="/blog" style="font-size: 0.875rem; color: var(--text-muted); transition: color 0.2s;" onmouseover="this.style.color='var(--accent)'" onmouseout="this.style.color='var(--text-muted)'">← Back to all posts</a>
      </div>
    </div>
  </article>
</BaseLayout>
