{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "date": {
      "type": "string",
      "format": "date-time"
    },
    "tags": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "summary": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "draft": {
      "default": false,
      "type": "boolean"
    },
    "lastmod": {
      "type": "string",
      "format": "date-time"
    },
    "images": {},
    "authors": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "layout": {
      "type": "string"
    },
    "bibliography": {
      "type": "string"
    },
    "canonicalUrl": {
      "type": "string"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "date"
  ]
}